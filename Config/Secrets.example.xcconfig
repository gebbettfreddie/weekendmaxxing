// Weekendmaxxing build configuration
//
// Setup:
//   1. Copy this file to Config/Secrets.xcconfig
//   2. Fill in your Travelpayouts token (https://www.travelpayouts.com)
//   3. Set USE_MOCK = NO to use live data
//
// The app runs fully on bundled mock data when USE_MOCK = YES or the
// token is left blank, so you are never blocked on keys.

// Your Travelpayouts (Aviasales) Data API token. Leave blank to force mock data.
TRAVELPAYOUTS_TOKEN =

// Optional affiliate marker (your Travelpayouts ID) used for booking links.
TRAVELPAYOUTS_MARKER =

// Flight proxy (Cloudflare Worker) that fronts SerpApi with a shared cache.
// Set PROXY_HOST to the deployed Worker host (NO https:// - xcconfig treats // as
// a comment), e.g. weekendmaxxing-proxy.yourname.workers.dev. The SerpApi key
// lives on the Worker, not here. PROXY_APP_TOKEN must match the Worker's APP_TOKEN.
PROXY_HOST =
PROXY_APP_TOKEN =

// YES = always use bundled sample data. NO = use Travelpayouts when a token exists.
USE_MOCK = YES
